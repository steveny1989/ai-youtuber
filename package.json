{
  "name": "ai-youtuber",
  "version": "1.0.0",
  "description": "从**结构化分镜 JSON**自动生成 YouTube 成片：旁白 TTS → 按镜头时间轴合成 → 硬字幕 → 导出 mp4。",
  "type": "module",
  "main": "app/server/index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node app/server/index.js",
    "dev:web": "vite --config app/vite.config.js",
    "build": "vite build --config app/vite.config.js",
    "preview": "vite preview --config app/vite.config.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steveny1989/ai-youtuber.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/steveny1989/ai-youtuber/issues"
  },
  "homepage": "https://github.com/steveny1989/ai-youtuber#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "vite": "^8.0.14"
  }
}
